# Security: Save exact versions (no ^ or ~)
# This prevents automatic installation of newer versions that could be malicious
save-exact=true

# Use package-lock for deterministic installs
package-lock=true

# Audit automatically on install
audit=true

# Fail on audit vulnerabilities (high/critical)
audit-level=high

# Note: The 'before' option for minimum release age is not supported in npm CLI
# Instead, we rely on:
# 1. Exact version pinning (above) - prevents auto-updates
# 2. Manual review process - all dependency updates require PR review
# 3. npm audit - catches known vulnerabilities
# 4. Lockfile verification - ensures reproducible installs
